# TP-Link Tapo アカウント
TAPO_USERNAME=your_email@example.com
TAPO_PASSWORD=your_password

# デバイスIP
RICE_COOKER_IP=192.168.x.x
IH_IP=
DRYER_IP=
HUB_IP=192.168.x.x

# カメラ
CAMERA_IP=192.168.x.x
CAMERA_USERNAME=your_camera_user
CAMERA_PASSWORD=your_camera_pass

# 判定しきい値 (W)
RICE_COOKER_THRESHOLD_W=100
IH_THRESHOLD_W=50

# OFF確定までの待機秒数（マイコン炊飯器のヒーターパルスOFFや蒸らしフェーズを跨ぐ）
RICE_COOKER_IDLE_CONFIRM=600

# ドライヤー監視（P110Mに挿す）— 髪洗い検知用
# 0なら無効、1以上なら該当node_idのMatterプラグを監視
HAIR_DRYER_NODE_ID=0
HAIR_DRYER_THRESHOLD_W=300

# 監視間隔 (秒)
POLL_INTERVAL=5

# 家族UI パスワード
FAMILY_PASSWORD=your_family_password

# 祖母宅Wi-Fi (GW設置時に使用)
GRANDMA_WIFI_SSID=your_wifi_ssid
GRANDMA_WIFI_PASS=your_wifi_password

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_token
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# webhook署名検証用（LINE Developers → Messaging API設定 → チャネルシークレット）
LINE_CHANNEL_SECRET=your_line_channel_secret
# webhookでURL返信を許可する送信者ID（カンマ区切り、未設定ならLINE_USER_IDを使用）
LINE_ALLOWED_SENDERS=

# アクセストークン（公開URL用）
TABLET_TOKEN=your_random_token
