[Unit]
Description=IoT Sensor Monitor (全センサー統合監視)
After=network-online.target iot-matter.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/iot-life-support
ExecStart=/home/pi/iot-life-support/venv/bin/python -m src.monitor
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
